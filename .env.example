# Wind Farm Data API — environment configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# ── Storage backend ────────────────────────────────────────────────────────
# "local"  → read parquet files from data/ directory (default for local dev)
# "r2"     → download parquet files from Cloudflare R2 into .r2_cache/
STORAGE_BACKEND=r2

# ── Cloudflare R2 credentials ──────────────────────────────────────────────
# Generate at: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT_URL=https://7cf52f0e0957036ef8b28411ed958be4.r2.cloudflarestorage.com
R2_BUCKET_NAME=windfarmdata
R2_ACCESS_KEY_ID=your-access-key-id-here
R2_SECRET_ACCESS_KEY=your-secret-access-key-here

